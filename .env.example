# =============================================================================
# SmartAgriMarket Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------

# Django secret key — used for cryptographic signing (sessions, CSRF, tokens).
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to True for local development, False for production.
# When True, detailed error pages are shown on exceptions.
DEBUG=True

# Comma-separated list of hostnames/IPs the server will accept requests for.
# Example: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------

# Name of the MySQL database.
DATABASE_NAME=

# MySQL user with access to the database.
DATABASE_USER=

# Password for the MySQL user.
DATABASE_PASSWORD=

# Hostname or IP where MySQL is running.
DATABASE_HOST=127.0.0.1

# Port MySQL is listening on (default: 3306).
DATABASE_PORT=3306

# -----------------------------------------------------------------------------
# Email (Gmail SMTP)
# -----------------------------------------------------------------------------
# Used for sending password-reset emails, alerts, and notifications.
# For Gmail, you need to generate an App Password:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new app password for "Mail"
#   4. Paste the 16-character password below (spaces included)

# Gmail address used as the sender.
EMAIL_HOST_USER=

# Gmail App Password (not your regular Gmail password).
EMAIL_HOST_PASSWORD=

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of frontend origins allowed to make API requests.
# Example: http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Firebase (Push Notifications)
# -----------------------------------------------------------------------------
# Path to the Firebase Admin SDK service account JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=